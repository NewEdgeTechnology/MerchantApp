# =========================
# USER ↔ MERCHANT CHAT (service)
# =========================
# ✅ Merchant list (business-only) — you already use this
MERCHANT_CHAT_CONVERSATIONS_URL=https://grab.newedge.bt/chat/chat/conversations

# ✅ Create/Get conversation for an order (works for both merchant & customer)
# (Your backend route is POST /chat/conversations/order/:orderId)
CHAT_CREATE_CONVERSATION_URL=https://grab.newedge.bt/chat/chat/conversations/order/:orderId

# ✅ Messages list for a conversation
CHAT_MESSAGES_URL=https://grab.newedge.bt/chat/chat/messages/:conversationId

# ✅ Send message (text or multipart image) to a conversation
CHAT_SEND_MESSAGE_URL=https://grab.newedge.bt/chat/chat/messages/:conversationId

# ✅ Mark read
CHAT_MARK_READ_URL=https://grab.newedge.bt/chat/chat/read/:conversationId

# ✅ Socket host + path (for realtime)
CHAT_SOCKET_ORIGIN=https://grab.newedge.bt
CHAT_SOCKET_PATH=/chat/socket.io

# ✅ (optional) base for merchant logos if you want consistent display
MERCHANT_LOGO_BASE=https://grab.newedge.bt/merchant

