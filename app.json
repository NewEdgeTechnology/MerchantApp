{
  "expo": {
    "name": "TàbDey Merchant",
    "slug": "tabdhey-merchant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_v2.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.tabdhey.tabdheymerchant",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "openstreetmap.org": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false
            },
            "tile.openstreetmap.org": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false
            },
            "router.project-osrm.org": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false
            }
          }
        },
        "NSLocationWhenInUseUsageDescription": "We need your location for business verification and nearby customer features.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to provide location-based services.",
        "NSCameraUsageDescription": "We need access to your camera to take business logo photos and scan documents.",
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to upload business logo and documents.",
        "NSFaceIDUsageDescription": "Allow Face ID/Touch ID to unlock your account.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tabdhey.tabdhey_merchant",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_v2.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      ["expo-build-properties"],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow TàbDhey to use your location for business verification and nearby customer features."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TàbDhey to access your camera for business logo photos and document uploads."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00B14F"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "39465596-f80e-4ebb-b661-e149cd200ad8"
      },
      "VERIFY_SESSION_ENDPOINT": "https://backend.tabdhey.bt/driver/api/verify-session"
    },
    "owner": "chospa"
  }
}
